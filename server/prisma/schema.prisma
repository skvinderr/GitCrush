// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  githubId        String    @unique
  accessToken     String?
  username        String
  avatarUrl       String
  bio             String?
  repos           Int       @default(0)
  followers       Int       @default(0)
  following       Int       @default(0)
  languages       Json?
  commitPattern   String?
  topics          String[]
  totalStars      Int       @default(0)
  experienceScore Int       @default(0)
  longestStreak   Int       @default(0)
  currentStreak   Int       @default(0)
  lastSyncedAt    DateTime?
  personalityType String?
  personalityDesc String?
  redFlags        Json?
  aiBio           String?
  customBio       String?
  bioRegenerations Int      @default(0)
  intent          String[]  @default(["Collaborator", "Friendship"])
  location        String?
  timezoneOffset  Int?
  createdAt       DateTime  @default(now())

  // Relations
  swipesGiven     Swipe[]   @relation("SwipesGiven")
  swipesReceived  Swipe[]   @relation("SwipesReceived")
}

model Swipe {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  swiperId       String   @db.ObjectId
  targetUserId   String   @db.ObjectId
  direction      String   // 'left', 'right', 'super'
  isMutualMatch  Boolean  @default(false)
  createdAt      DateTime @default(now())

  swiper         User     @relation("SwipesGiven", fields: [swiperId], references: [id])
  targetUser     User     @relation("SwipesReceived", fields: [targetUserId], references: [id])

  @@unique([swiperId, targetUserId])
}

model CompatibilityCache {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userAId     String   @db.ObjectId
  userBId     String   @db.ObjectId
  score       Int
  explanation String
  computedAt  DateTime @default(now())

  @@unique([userAId, userBId])
}

